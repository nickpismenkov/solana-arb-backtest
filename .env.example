# Yellowstone gRPC (Tatum free tier works) — Turbine-sourced price feed for `shadow`.
GRPC_ENDPOINT=https://solana-mainnet-grpc.gateway.tatum.io
GRPC_X_TOKEN=

# ShredStream UDP listen port (register the box IP with your shred provider).
SHREDSTREAM_PORT=20000

# JSON-RPC endpoint for victim simulation + pool-state reads (backrun_probe,
# tickarray_probe). Slow is OK — measurement only. Do NOT commit real keys.
RPC_ENDPOINT=

# Jito block engine (co-located region). Used by jito_probe.
JITO_BLOCK_ENGINE=https://amsterdam.mainnet.block-engine.jito.wtf

# Run duration for timed probes, in ms.
RUN_MS=600000
