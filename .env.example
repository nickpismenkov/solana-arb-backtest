# Yellowstone gRPC (Tatum free tier works) — Turbine-sourced price feed for `shadow`.
GRPC_ENDPOINT=https://solana-mainnet-grpc.gateway.tatum.io
GRPC_X_TOKEN=

# ShredStream UDP listen port (register the box IP with your shred provider).
SHREDSTREAM_PORT=20000

# JSON-RPC endpoint for victim simulation + pool-state reads (backrun_probe,
# tickarray_probe). Slow is OK — measurement only. Do NOT commit real keys.
RPC_ENDPOINT=

# Jito block engine (co-located region). Used by jito_probe.
JITO_BLOCK_ENGINE=https://amsterdam.mainnet.block-engine.jito.wtf

# Run duration for timed probes, in ms.
RUN_MS=600000

# ── Liquidation executors (liq_executor = marginfi, liq_kamino_executor) ─────
# Full RPC for scan + simulate + submit-readback (getProgramAccounts-capable).
HELIUS_RPC=
# Funded hot wallet keypair (authority = DYeYAvJS…). SOL pays tips + fees only
# (liquidations use flash loans → no inventory capital).
KEYPAIR_PATH=~/arb-keypair.json
# Safety default: never submits. Flip to 0 ONLY to go live.
DRY_RUN=1
# Pyth Lazer WS token (pre-positioning). Unset → lazer=false (poll-only).
PYTH_LAZER_TOKEN=
# Alert webhook (Slack/Discord) for landed/miss/cap/floor events.
ALERT_WEBHOOK=
# Guardrails (defaults shown): min profit to fire, tip = % of profit, daily tip
# cap, wallet floor below which it won't fire.
MIN_PROFIT_USD=0.5
TIP_FRACTION_BPS=3000
MAX_DAILY_TIP_SOL=0.05
WALLET_MIN_SOL=0.02
# On-chain lookup tables created for the fire paths (override if recreated):
#   marginfi: DEMhLvSJbSZQfCdiH7YicYNopo3EhhapjfoEjt2kJVij  (LIQ_ALT)
#   kamino:   6X77KtDupVYqU4SBjWsY93ycFW2bPm3AWpAuPWfxraKo  (KAMINO_ALT)

# ── Pair override (defaults = liquid SOL/USDC) ──────────────────────────────
# Re-point the whole engine at any pair with a pool on BOTH venues.
# PAIR_LABEL=SPYx/USDC
# ORCA_POOL=<whirlpool address>
# RAY_CLMM_POOL=<raydium clmm pool address>
# BASE_MINT=<mint prices are quoted against (quote-per-base)>
# BASE_DECIMALS=9
# QUOTE_DECIMALS=6
# ORCA_FEE_BPS=2
# RAY_FEE_BPS=1
# RAY_VAULT0=<ray clmm token_vault_0 (direction decode)>
